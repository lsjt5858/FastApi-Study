# Blog API 配置模板 —— 复制为 .env 并按需修改
# cp .env.example .env

# 数据库连接（开发用 sqlite，生产用 postgresql+asyncpg）
DATABASE_URL="sqlite+aiosqlite:///./blog.db"

# JWT 签名密钥 —— 生产环境务必用 openssl rand -hex 32 生成
SECRET_KEY="change-me-with-a-long-random-string"

# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# JWT 算法
ALGORITHM=HS256

# 调试模式
DEBUG=false

# 开发/教学部署可打开，应用启动时自动 create_all；生产建议关闭并使用 Alembic
INIT_DB_ON_STARTUP=false

# Redis 连接（task-18 缓存用）
REDIS_URL="redis://localhost:6379/0"
